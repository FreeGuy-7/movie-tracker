# Copy this file to .env, then fill in your values. Never commit .env.
# Admin account created on first startup. Change these before deploying.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password
# Required to allow new users to sign up.
SIGNUP_ACCESS_KEY=share-a-long-random-key
# Optional admin Discord ID for admin-created triggers.
ADMIN_DISCORD_USER_ID=
# Create a separate Discord webhook URL for each message stream.
DISCORD_STATUS_WEBHOOK_URL=
DISCORD_TRIGGER_WEBHOOK_URL=
DISCORD_NEW_SHOW_WEBHOOK_URL=
DISCORD_MENTION=@here
# For a user mention, use the numeric Discord user ID, not username/display name.
# DISCORD_USER_ID=123456789012345678
HEARTBEAT_MINUTES=60
PORT=8080
DATA_DIR=data
DB_PATH=data/database
# Set to 1 when serving behind HTTPS.
COOKIE_SECURE=0
# Optional local diagnostics. Leave unset in deployments to avoid log files.
# DEBUG_LOG_PATH=debug.log
